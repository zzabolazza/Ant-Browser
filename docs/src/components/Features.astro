---
const features = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
    title: '实例隔离',
    desc: '每个账号独立浏览器环境，Cookie、LocalStorage、IndexedDB 互不干扰',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />`,
    title: '代理绑定',
    desc: '支持 direct / http / https / socks5，按实例分配独立代理出口',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />`,
    title: '内核管理',
    desc: '维护多个 Chromium 内核版本，一键切换默认内核',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
    title: '插件管理',
    desc: '安装、导入、启停、删除，支持实例级插件限制',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />`,
    title: '实例迁移',
    desc: 'ZIP 打包导出完整用户数据，跨设备导入为新实例',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    title: 'Launch API',
    desc: '本地 HTTP 接口，供外部系统按 Code / 名称 / 标签调用浏览器实例',
  },
]
---
<section class="py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl">
      功能概览
    </h2>
    <p class="mx-auto mb-14 max-w-xl text-center text-muted">
      从实例隔离到外部 API 调用，覆盖多账号浏览器管理的完整链路。
    </p>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="group rounded-2xl border border-surface-border bg-surface-card p-6 transition hover:border-accent-from/30">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-accent-from/15 to-accent-to/15 text-accent-from">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={f.icon} />
          </div>
          <h3 class="mb-2 text-[15px] font-semibold">{f.title}</h3>
          <p class="text-sm leading-relaxed text-muted">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
