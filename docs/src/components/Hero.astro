---
const BASE = import.meta.env.BASE_URL
---

<section id="top" class="relative overflow-hidden pb-24 pt-32 sm:pt-36 lg:min-h-[880px] lg:pb-32 lg:pt-44">
  <div class="page-grid pointer-events-none absolute inset-x-0 top-0 h-[760px]"></div>
  <div class="pointer-events-none absolute left-[8%] top-28 h-72 w-72 rounded-full bg-violet-600/10 blur-[100px]"></div>
  <div class="pointer-events-none absolute right-[4%] top-52 h-80 w-80 rounded-full bg-cyan-400/10 blur-[120px]"></div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-16 px-6 lg:grid-cols-[0.9fr_1.1fr] lg:gap-10 xl:gap-14">
    <div class="max-w-2xl">
      <a
        href="https://github.com/zzabolazza/Facade/releases/tag/v1.3.6"
        target="_blank"
        rel="noopener noreferrer"
        class="mb-7 inline-flex items-center gap-2 rounded-full border border-indigo-400/20 bg-indigo-400/[0.08] px-3 py-1.5 text-xs font-medium text-indigo-200 transition hover:border-indigo-300/30 hover:bg-indigo-400/[0.12]"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-cyan-300 shadow-[0_0_12px_rgba(103,232,249,.9)]"></span>
        v1.3.6 已发布
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" />
        </svg>
      </a>

      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300/80">One Facade. Endless Faces.</p>
      <h1 class="text-[2.8rem] font-bold leading-[1.08] tracking-[-0.04em] text-white sm:text-6xl lg:text-[3.25rem] xl:text-[3.7rem]">
        <span class="lg:whitespace-nowrap">让每一个账号，</span><br />
        <span class="gradient-text lg:hidden">拥有自己的<br />浏览器空间</span>
        <span class="gradient-text hidden whitespace-nowrap lg:inline">拥有自己的浏览器空间</span>
      </h1>
      <p class="mt-7 max-w-xl text-base leading-8 text-muted sm:text-lg">
        Facade 将浏览器实例、代理出口、内核与扩展统一到一个本地工作台。环境彼此隔离，状态清晰可见，随时一键启动。
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a
          href="#download"
          class="group inline-flex h-12 items-center justify-center gap-2 whitespace-nowrap rounded-xl bg-gradient-to-r from-accent-from to-accent-blue px-6 text-sm font-semibold text-white shadow-[0_12px_36px_rgba(90,76,255,.28)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_42px_rgba(90,76,255,.38)]"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
          </svg>
          下载最新版
        </a>
        <a
          href="https://github.com/zzabolazza/Facade"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-12 items-center justify-center gap-2 whitespace-nowrap rounded-xl border border-white/10 bg-white/[0.035] px-6 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/[0.07]"
        >
          查看源代码
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-5-5 5 5-5 5" />
          </svg>
        </a>
      </div>

      <div class="mt-9 flex flex-wrap gap-x-6 gap-y-3 text-xs font-medium text-muted">
        <span class="inline-flex items-center gap-2"><svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6" /></svg>数据保留在本地</span>
        <span class="inline-flex items-center gap-2"><svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6" /></svg>跨平台支持</span>
        <span class="inline-flex items-center gap-2"><svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6" /></svg>开源可审计</span>
      </div>
    </div>

    <div class="relative mx-auto w-full max-w-[760px]">
      <div class="pointer-events-none absolute -inset-8 rounded-[40px] bg-gradient-to-br from-indigo-500/20 via-transparent to-cyan-400/15 blur-3xl"></div>
      <div class="relative overflow-hidden rounded-[22px] border border-white/[0.13] bg-[#0b0f19] shadow-[0_40px_100px_rgba(0,0,0,.55)]">
        <div class="flex h-11 items-center border-b border-white/[0.07] bg-white/[0.025] px-4">
          <div class="flex gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff665c]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd45]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#26c845]"></span>
          </div>
          <div class="mx-auto flex items-center gap-2 pr-10 text-[10px] font-medium text-[#7f899f]">
            <img src={`${BASE}appicon.png`} alt="" class="h-4 w-4 rounded-[4px]" />
            Facade Workspace
          </div>
        </div>

        <div class="grid min-h-[390px] grid-cols-[76px_1fr] sm:min-h-[455px] sm:grid-cols-[154px_1fr]">
          <aside class="border-r border-white/[0.07] bg-[#0c101b] p-3 sm:p-4">
            <div class="mb-6 hidden items-center gap-2.5 px-1 sm:flex">
              <img src={`${BASE}appicon.png`} alt="" class="h-7 w-7 rounded-lg" />
              <span class="text-[11px] font-bold tracking-[0.14em] text-white">FACADE</span>
            </div>
            <nav class="space-y-1.5 text-[10px] font-medium text-[#778198]">
              <div class="flex items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-indigo-500/20 to-blue-500/10 px-2 py-2.5 text-indigo-200 sm:justify-start sm:px-3">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="15" rx="2" /><path d="M3 9h18" /></svg>
                <span class="hidden sm:inline">浏览器实例</span>
              </div>
              <div class="flex items-center justify-center gap-2 rounded-lg px-2 py-2.5 sm:justify-start sm:px-3">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" /></svg>
                <span class="hidden sm:inline">代理资源池</span>
              </div>
              <div class="flex items-center justify-center gap-2 rounded-lg px-2 py-2.5 sm:justify-start sm:px-3">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path d="M8 4h8v4h4v8h-4v4H8v-4H4V8h4V4Z" /></svg>
                <span class="hidden sm:inline">内核管理</span>
              </div>
              <div class="flex items-center justify-center gap-2 rounded-lg px-2 py-2.5 sm:justify-start sm:px-3">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" /><path d="m4 7.5 8 4.5 8-4.5M12 12v9" /></svg>
                <span class="hidden sm:inline">扩展管理</span>
              </div>
            </nav>
          </aside>

          <div class="min-w-0 bg-[#090d17] p-4 sm:p-5 lg:p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h2 class="text-sm font-semibold text-white sm:text-base">浏览器实例</h2>
                <p class="mt-1 hidden text-[10px] text-[#6f7990] sm:block">管理隔离环境、代理与启动状态</p>
              </div>
              <button class="flex h-8 items-center gap-1.5 rounded-lg bg-indigo-500 px-2.5 text-[9px] font-semibold text-white sm:px-3">
                <span class="text-sm leading-none">＋</span><span class="hidden sm:inline">新增实例</span>
              </button>
            </div>

            <div class="mt-5 grid grid-cols-3 gap-2 sm:gap-3">
              <div class="rounded-xl border border-white/[0.07] bg-white/[0.025] p-2.5 sm:p-3.5">
                <p class="text-[8px] text-[#69748b] sm:text-[9px]">全部实例</p>
                <p class="mt-1 text-lg font-semibold text-white sm:text-2xl">24</p>
              </div>
              <div class="rounded-xl border border-white/[0.07] bg-white/[0.025] p-2.5 sm:p-3.5">
                <p class="text-[8px] text-[#69748b] sm:text-[9px]">运行中</p>
                <p class="mt-1 text-lg font-semibold text-emerald-400 sm:text-2xl">08</p>
              </div>
              <div class="rounded-xl border border-white/[0.07] bg-white/[0.025] p-2.5 sm:p-3.5">
                <p class="text-[8px] text-[#69748b] sm:text-[9px]">代理可用</p>
                <p class="mt-1 text-lg font-semibold text-cyan-300 sm:text-2xl">96%</p>
              </div>
            </div>

            <div class="mt-4 flex h-8 items-center gap-2 rounded-lg border border-white/[0.07] bg-white/[0.02] px-3 text-[9px] text-[#657087]">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7" /><path d="m20 20-4-4" /></svg>
              搜索名称、Code 或标签
            </div>

            <div class="mt-3 overflow-hidden rounded-xl border border-white/[0.07]">
              <div class="grid grid-cols-[1.5fr_.8fr_.65fr] bg-white/[0.035] px-3 py-2 text-[8px] font-medium uppercase tracking-wider text-[#657087] sm:grid-cols-[1.45fr_1fr_.8fr_.55fr] sm:px-4">
                <span>实例</span><span>代理</span><span>状态</span><span class="hidden text-right sm:block">操作</span>
              </div>
              {[
                ['A', 'Amazon US', 'US · Seattle', '运行中', 'from-indigo-500 to-violet-500'],
                ['S', 'Shopify Store', 'JP · Tokyo', '已停止', 'from-cyan-500 to-blue-500'],
                ['M', 'Meta Business', 'DE · Frankfurt', '运行中', 'from-fuchsia-500 to-pink-500'],
                ['T', 'TikTok Shop', 'SG · Singapore', '已停止', 'from-amber-400 to-orange-500'],
              ].map((row, index) => (
                <div class:list={["grid grid-cols-[1.5fr_.8fr_.65fr] items-center px-3 py-2.5 text-[8px] sm:grid-cols-[1.45fr_1fr_.8fr_.55fr] sm:px-4 sm:py-3 sm:text-[9px]", index < 3 && "border-b border-white/[0.055]"]}>
                  <div class="flex min-w-0 items-center gap-2">
                    <span class:list={["flex h-6 w-6 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br text-[8px] font-bold text-white", row[4]]}>{row[0]}</span>
                    <span class="truncate font-medium text-[#dce2f1]">{row[1]}</span>
                  </div>
                  <span class="truncate text-[#7f899f]">{row[2]}</span>
                  <span class:list={["inline-flex items-center gap-1", row[3] === '运行中' ? 'text-emerald-400' : 'text-[#707b92]']}>
                    <i class:list={["h-1.5 w-1.5 rounded-full", row[3] === '运行中' ? 'bg-emerald-400' : 'bg-[#505a70]']}></i>{row[3]}
                  </span>
                  <span class="hidden text-right text-indigo-300 sm:block">{row[3] === '运行中' ? '管理' : '启动'}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="absolute -bottom-5 -left-4 hidden items-center gap-3 rounded-2xl border border-white/10 bg-[#111625]/90 px-4 py-3 shadow-2xl backdrop-blur-xl sm:flex">
        <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-400/10 text-emerald-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6" /></svg>
        </span>
        <span><strong class="block text-[11px] text-white">代理连接正常</strong><small class="mt-0.5 block text-[9px] text-muted">延迟 42ms · US West</small></span>
      </div>
    </div>
  </div>
</section>
