---
const BASE = import.meta.env.BASE_URL
---

<footer class="border-t border-white/[0.07] bg-[#080b13] py-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 px-6 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <img src={`${BASE}appicon.png`} alt="Facade" class="h-10 w-10 rounded-xl" />
      <div>
        <p class="text-sm font-bold tracking-[0.14em] text-white">FACADE</p>
        <p class="mt-1 text-[10px] text-muted">One Facade. Endless Faces.</p>
      </div>
    </div>

    <nav class="flex flex-wrap items-center gap-x-6 gap-y-3 text-xs font-medium text-muted">
      <a href="#features" class="transition hover:text-white">核心能力</a>
      <a href="#download" class="transition hover:text-white">下载</a>
      <a href="https://github.com/zzabolazza/Facade" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">GitHub</a>
      <a href="https://github.com/zzabolazza/Facade/issues" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">Issues</a>
    </nav>

    <div class="text-xs text-[#566078] sm:text-right">
      <p>© 2026 Facade Team</p>
      <p class="mt-1">Open source on GitHub</p>
    </div>
  </div>
</footer>
