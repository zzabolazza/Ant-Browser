---
const platforms = [
  {
    name: 'Windows',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />`,
    file: 'Facade-Setup-*.exe',
    note: '安装版 / 便携版',
    url: 'https://github.com/zzabolazza/Facade/releases',
  },
  {
    name: 'Linux',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />`,
    file: 'facade_*.deb',
    note: '推荐 apt install',
    url: 'https://github.com/zzabolazza/Facade/releases',
  },
  {
    name: 'macOS',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 7.41A2.25 2.25 0 012.25 5.495V5.25" />`,
    file: 'Facade-*.app',
    note: 'unsigned 内测包',
    url: 'https://github.com/zzabolazza/Facade/releases',
  },
]
---
<section class="bg-surface-card/30 py-20 md:py-28">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl">
      下载 Facade
    </h2>
    <p class="mx-auto mb-14 max-w-xl text-center text-muted">
      支持 Windows、Linux、macOS，选择对应平台即可下载。
    </p>

    <div class="grid gap-6 sm:grid-cols-3">
      {platforms.map((p) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-center rounded-2xl border border-surface-border bg-surface-card p-8 text-center transition hover:border-accent-from/30 hover:shadow-lg hover:shadow-accent-from/5"
        >
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-accent-from/15 to-accent-to/15 text-accent-from transition group-hover:scale-105">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={p.icon} />
          </div>
          <h3 class="mb-1 text-lg font-semibold">{p.name}</h3>
          <p class="mb-4 text-xs text-muted">{p.note}</p>
          <span class="mt-auto inline-flex items-center gap-1 text-sm font-medium text-accent-from transition group-hover:gap-2">
            下载
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-muted">
      当前版本：<span class="font-mono text-text/70">v1.3.2</span>
      &nbsp;·&nbsp;
      <a href="https://github.com/zzabolazza/Facade/blob/master/CHANGELOG.md" class="text-accent-from/80 hover:text-accent-from">更新日志</a>
    </p>
  </div>
</section>
