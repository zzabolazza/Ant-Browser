---
const BASE = import.meta.env.BASE_URL
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between rounded-2xl border border-white/[0.08] bg-[#0a0d17]/80 px-4 shadow-2xl shadow-black/20 backdrop-blur-xl sm:px-5">
    <a href="#top" class="flex items-center gap-3" aria-label="Facade 首页">
      <img src={`${BASE}appicon.png`} alt="" class="h-9 w-9 rounded-[10px] shadow-lg shadow-indigo-500/10" />
      <div class="leading-none">
        <div class="text-[15px] font-bold tracking-[0.16em] text-white">FACADE</div>
        <div class="mt-1 hidden text-[9px] font-medium tracking-[0.18em] text-muted sm:block">BROWSER WORKSPACE</div>
      </div>
    </a>

    <nav class="hidden items-center gap-7 text-[13px] font-medium text-muted md:flex" aria-label="主导航">
      <a href="#features" class="transition hover:text-white">核心能力</a>
      <a href="#workflow" class="transition hover:text-white">工作方式</a>
      <a href="#download" class="transition hover:text-white">下载</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/zzabolazza/Facade"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden h-9 items-center gap-2 rounded-xl border border-white/10 px-3 text-xs font-medium text-muted transition hover:border-white/20 hover:bg-white/[0.04] hover:text-white sm:inline-flex"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.21.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23A11.5 11.5 0 0 1 12 6.8c1.02 0 2.05.14 3.01.4 2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.3c0 .32.19.69.8.57A12 12 0 0 0 12 0Z" />
        </svg>
        GitHub
      </a>
      <a href="#download" class="inline-flex h-9 items-center rounded-xl bg-white px-4 text-xs font-semibold text-[#090c16] transition hover:bg-[#dfe6ff]">
        获取 Facade
      </a>
    </div>
  </div>
</header>
